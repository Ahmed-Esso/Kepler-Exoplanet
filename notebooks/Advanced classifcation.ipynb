    "# Define Features and Target\n",
    "X = df_cls.drop(columns=['koi_disposition', 'target'])\n",
    "y = df_cls['target']\n",
    "\n",
    "display(y.value_counts())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 57,
   "id": "3f0fa4e5-b08a-44af-b794-3b69e9aa0fcd",
