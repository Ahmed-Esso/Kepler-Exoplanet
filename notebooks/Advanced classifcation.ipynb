                                     "# Apriori Frequent Itemsets (min_support = 0.2)`n",
                                     "from mlxtend.frequent_patterns import apriori`n",
                                     "`n",
                                     "# Use existing in-memory dataset`n",
                                     "row_count_before = len(df_cls)`n",
                                     "`n",
                                     "# Exclude likely identifier/label columns`n",
                                     "exclude_cols = {\"transaction_id\", \"invoice\", \"invoice_no\", \"customer_id\", \"koi_disposition\", \"target\"}`n",
                                     "id_like = [c for c in df_cls.columns if c.lower() in exclude_cols or c.lower().endswith(\"_id\")]`n",
                                     "item_cols = [c for c in df_cls.columns if c not in id_like]`n",
                                     "`n",
                                     "truthy = {1, True, \"1\", \"true\", \"yes\", \"y\", \"t\"}`n",
                                     "falsy = {0, False, \"0\", \"false\", \"no\", \"n\", \"f\"}`n",
                                     "`n",
                                     "def _to_binary(v):`n",
                                     "    if v is None:`n",
                                     "        return 0`n",
                                     "    if isinstance(v, str):`n",
                                     "        v = v.strip().lower()`n",
                                     "    if v in truthy:`n",
                                     "        return 1`n",
                                     "    if v in falsy:`n",
                                     "        return 0`n",
                                     "    if isinstance(v, (int, float)):`n",
                                     "        return 1 if v \u003e 0 else 0`n",
                                     "    raise ValueError(f\"Non-binary value found: {v!r}\")`n",
                                     "`n",
                                     "# Normalize selected item columns to one-hot`n",
                                     "df_cls.loc[:, item_cols] = df_cls[item_cols].applymap(_to_binary).astype(\"uint8\")`n",
                                     "`n",
                                     "# Validate one-hot matrix`n",
                                     "item_matrix = df_cls[item_cols]`n",
                                     "assert item_matrix.isnull().sum().sum() == 0, \"Null values exist in item matrix after coercion\"`n",
                                     "invalid_cols = [c for c in item_matrix.columns if not set(item_matrix[c].unique()).issubset({0, 1})]`n",
                                     "assert not invalid_cols, f\"Non-binary columns after coercion: {invalid_cols}\"`n",
                                     "assert len(df_cls) == row_count_before, \"Row count changed during one-hot normalization\"`n",
                                     "`n",
                                     "# Run Apriori with minimum support = 0.2`n",
                                     "frequent_itemsets = apriori(item_matrix.astype(bool), min_support=0.2, use_colnames=True)`n",
                                     "`n",
                                     "# Sort for readability and display`n",
                                     "frequent_itemsets = frequent_itemsets.sort_values(\"support\", ascending=False).reset_index(drop=True)`n",
                                     "print(\"Frequent itemsets found:\", len(frequent_itemsets))`n",
                                     "frequent_itemsets`n"
                                 ]
                  },
                  {
                      "cell_type":  "markdown",
                      "metadata":  {

                                   },
                      "source":  [
                                     "This step identifies frequently co-occurring items in transactions by finding item combinations that appear together in at least 20% of transactions."
                                 ]
                  }
