            box-shadow:0 0 20px rgba(0,240,255,.28), 0 0 10px rgba(255,0,127,.2) inset !important;
            background:rgba(20,50,90,0.35) !important;
        }}
        [data-baseweb="tab-highlight"] {{background:{GALAXY_ACCENT1} !important; height:3px !important;}}
        </style>
        """,
        unsafe_allow_html=True,
    )


def gfig(fig: go.Figure, h: int = 420) -> go.Figure:
    fig.update_layout(
        template=None,
        height=h,
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor=GALAXY_BG,
        font=dict(color=GALAXY_FG, family="Share Tech Mono"),
        margin=dict(l=30, r=30, t=52, b=24),
        legend=dict(bgcolor="rgba(3,0,20,.75)", bordercolor=GALAXY_BORDER, borderwidth=1),
    )
    fig.update_xaxes(showgrid=True, gridcolor=GALAXY_GRID, linecolor=GALAXY_BORDER)
    fig.update_yaxes(showgrid=True, gridcolor=GALAXY_GRID, linecolor=GALAXY_BORDER)
    return fig


def gauge(value: float, title: str, color: str) -> go.Figure:
    fig = go.Figure(go.Indicator(
        mode="gauge+number",
        value=value * 100,
        number={"suffix": "%", "font": {"color": GALAXY_FG, "size": 50}},
        title={"text": title, "font": {"color": GALAXY_FG, "size": 14}},
        gauge={
            "axis": {"range": [0, 100], "tickcolor": GALAXY_FG},
            "bar": {"color": color, "thickness": 0.8},
            "bgcolor": "rgba(255,255,255,.03)",
            "bordercolor": GALAXY_BORDER,
        },
    ))
    return gfig(fig, 430)


def eda_hist_grid(df: pd.DataFrame) -> go.Figure:
    fig = make_subplots(rows=4, cols=4, subplot_titles=FEATURE_COLS)
    palette = [GALAXY_ACCENT2, GALAXY_ACCENT1, GALAXY_ACCENT3, GALAXY_ACCENT4]
    for i, col in enumerate(FEATURE_COLS):
        r = (i // 4) + 1
        c = (i % 4) + 1
        vals = np.log1p(df[col].clip(lower=0)) if col in SKEWED_FEATURES else df[col]
        fig.add_trace(
            go.Histogram(
                x=vals,
                nbinsx=40,
                marker=dict(color=palette[i % len(palette)], line=dict(color=GALAXY_BG, width=1)),
                opacity=0.88,
                showlegend=False,
            ),
            row=r,
            col=c,
        )
    fig.update_layout(
        title="Feature Distributions (Cleaned Data, log1p for skewed features)",
        bargap=0.08,
    )
    return gfig(fig, 980)


def eda_boxplot_grid(df: pd.DataFrame) -> go.Figure:
    key_features = [
        "koi_prad", "koi_period", "koi_depth", "koi_duration",
        "koi_impact", "koi_model_snr", "koi_teq", "koi_insol",
    ]
    order = ["CONFIRMED", "CANDIDATE", "FALSE POSITIVE"]
    fig = make_subplots(rows=2, cols=4, subplot_titles=key_features)

    for i, col in enumerate(key_features):
        r = (i // 4) + 1
        c = (i % 4) + 1
        y = np.log1p(df[col].clip(lower=0))
        for cls in order:
            m = df["koi_disposition"] == cls
            cls_color = GALAXY_CLASS_PALETTE.get(cls, GALAXY_ACCENT2)
            fig.add_trace(
                go.Box(
                    x=[cls] * int(m.sum()),
                    y=y[m],
                    name=cls,
                    marker=dict(color=cls_color, size=3, opacity=0.45),
                    fillcolor=cls_color.replace(")", ",0.28)") if cls_color.startswith("rgba") else cls_color + "55",
                    line=dict(color=cls_color, width=2),
                    boxpoints=False,
                    showlegend=(i == 0),
                ),
                row=r,
                col=c,
            )
    fig.update_layout(title="Key Features vs. Disposition (log1p scale, fliers hidden)")
    return gfig(fig, 760)


@st.cache_data(show_spinner=False)
def load_raw() -> pd.DataFrame:
    return pd.read_csv(DATA_PATH)


@st.cache_data(show_spinner=False)
def load_metrics() -> pd.DataFrame:
    m = pd.read_csv(METRICS_PATH)
    m["Score_Avg"] = m[["Accuracy", "ROC-AUC", "F1-Score"]].mean(axis=1)
    return m.sort_values("Score_Avg", ascending=False).reset_index(drop=True)


@st.cache_data(show_spinner=False)
def load_analysis(df: pd.DataFrame) -> pd.DataFrame:
    out = df[FEATURE_COLS + ["koi_disposition"]].copy()
    for c in FEATURE_COLS:
        out[c] = out[c].fillna(out[c].median())
    return out


@st.cache_resource(show_spinner=False)
def load_models() -> Dict[str, object]:
    return {name: joblib.load(path) for name, path in MODEL_PATHS.items()}


def build_roc_figure(df: pd.DataFrame, models: Dict[str, object]) -> go.Figure:
    bdf = df[df["koi_disposition"].isin(["CONFIRMED", "FALSE POSITIVE"])].copy()
    y = bdf["koi_disposition"].map({"FALSE POSITIVE": 0, "CONFIRMED": 1}).astype(int).values
    x = bdf[FEATURE_COLS]

    fig = go.Figure()
    palette = [GALAXY_ACCENT2, GALAXY_ACCENT1, GALAXY_ACCENT3, GALAXY_ACCENT4]

    for i, (name, model) in enumerate(models.items()):
        if not hasattr(model, "predict_proba"):
            continue
        proba = model.predict_proba(x)[:, 1]
        fpr, tpr, _ = roc_curve(y, proba)
        auc_val = auc(fpr, tpr)
        fig.add_trace(
            go.Scatter(
                x=fpr,
                y=tpr,
                mode="lines",
                name=f"{name} (AUC={auc_val:.3f})",
                line=dict(color=palette[i % len(palette)], width=3),
            )
        )

    fig.add_trace(
        go.Scatter(
            x=[0, 1],
            y=[0, 1],
            mode="lines",
            name="Random",
            line=dict(color="rgba(255,255,255,0.45)", dash="dash"),
        )
    )
    fig.update_layout(title="ROC Curves - Binary Classification")
    fig.update_xaxes(title="False Positive Rate")
    fig.update_yaxes(title="True Positive Rate")
    return gfig(fig, 520)


st.set_page_config(page_title="Kepler Exoplanet Intelligence Dashboard", layout="wide", initial_sidebar_state="collapsed")
inject_css()

raw_df = load_raw()
analysis = load_analysis(raw_df)
metrics_df = load_metrics()
models = load_models()

st.markdown("<div class='title-main'>Kepler Exoplanet Intelligence Dashboard</div>", unsafe_allow_html=True)
st.markdown("<div class='title-sub'>Centered layout with full-dataset analytics, model insights, and real-time inference.</div>", unsafe_allow_html=True)

tab_main, tab_eda, tab_models, tab_infer, tab_rules = st.tabs([
    "Mission Overview", "EDA Analytics", "Model Performance", "Model Inference", "Association Rules"
])

# center filter under tabs
c1, c2, c3 = st.columns([0.22, 0.56, 0.22])
with c2:
    dispositions = sorted(analysis["koi_disposition"].dropna().unique().tolist())
    st.markdown("<div style='text-align:center;font-family:Orbitron;margin-bottom:6px;'>Global Filters</div>", unsafe_allow_html=True)
    sel_disp = st.multiselect("Disposition", dispositions, default=dispositions)
    p_min, p_max = float(analysis["koi_period"].min()), float(analysis["koi_period"].max())
    r_min, r_max = float(analysis["koi_prad"].min()), float(analysis["koi_prad"].max())
    t_min, t_max = float(analysis["koi_steff"].min()), float(analysis["koi_steff"].max())
    period_rng = st.slider("Orbital Period", p_min, p_max, (p_min, p_max))
    radius_rng = st.slider("Planet Radius", r_min, r_max, (r_min, r_max))
    temp_rng = st.slider("Stellar Temp", t_min, t_max, (t_min, t_max))

fdf = analysis[
    analysis["koi_disposition"].isin(sel_disp)
    & analysis["koi_period"].between(*period_rng)
    & analysis["koi_prad"].between(*radius_rng)
    & analysis["koi_steff"].between(*temp_rng)
].copy()
if fdf.empty:
    st.warning("No records match the current filter.")
    st.stop()

with tab_main:
    total = len(fdf)
    conf = int((fdf["koi_disposition"] == "CONFIRMED").sum())
    fp = int((fdf["koi_disposition"] == "FALSE POSITIVE").sum())
    cand = int((fdf["koi_disposition"] == "CANDIDATE").sum())

    st.markdown(
        f"""
        <div class='kpi-grid'>
          <div class='kpi-card cyan'><div class='kpi-label'>Total Dataset</div><div class='kpi-value'>{total:,}</div><div class='kpi-sub'>All records</div></div>
          <div class='kpi-card cyan'><div class='kpi-label'>Confirmed</div><div class='kpi-value'>{conf:,}</div><div class='kpi-sub'>{(conf/max(total,1))*100:.1f}% of total set</div></div>
          <div class='kpi-card pink'><div class='kpi-label'>False Positive</div><div class='kpi-value'>{fp:,}</div><div class='kpi-sub'>Binary-class counterpart</div></div>
          <div class='kpi-card purple'><div class='kpi-label'>Candidate</div><div class='kpi-value'>{cand:,}</div><div class='kpi-sub'>Needs additional confirmation</div></div>
        </div>
        """,
        unsafe_allow_html=True,
    )

    counts = fdf["koi_disposition"].value_counts()
    fig_donut = go.Figure(go.Pie(
        labels=counts.index.tolist(),
        values=counts.values.tolist(),
        hole=0.66,
        marker=dict(colors=[GALAXY_CLASS_PALETTE.get(x, GALAXY_ACCENT2) for x in counts.index]),
    ))
    fig_donut.update_layout(title="Disposition Mix")

    best = metrics_df.iloc[0]
    col1, col2, col3 = st.columns([1.25, 1, 1])
    with col1:
        st.plotly_chart(gfig(fig_donut, 430), use_container_width=True, theme=None)
    with col2:
        st.plotly_chart(gauge(float(best["Accuracy"]), f"Best Accuracy: {best['Model']}", GALAXY_ACCENT1), use_container_width=True, theme=None)
    with col3:
        st.plotly_chart(gauge(float(best["ROC-AUC"]), f"Best ROC AUC: {best['Model']}", GALAXY_ACCENT3), use_container_width=True, theme=None)

    st.markdown("<div class='section-header'>Mission Visual Insights</div>", unsafe_allow_html=True)
    v1, v2 = st.columns([1, 1.35])
    with v1:
        cnt = fdf["koi_disposition"].value_counts().reset_index()
        cnt.columns = ["Disposition", "Count"]
        fig_bar = px.bar(
            cnt,
            x="Disposition",
            y="Count",
            color="Disposition",
            color_discrete_map=GALAXY_CLASS_PALETTE,
            text="Count",
            title="Class Count Snapshot",
        )
        fig_bar.update_traces(textposition="outside")
        st.plotly_chart(gfig(fig_bar, 360), use_container_width=True, theme=None)

    with v2:
        sd = fdf.sample(min(3200, len(fdf)), random_state=11).copy()
        sd["log1p(koi_period)"] = np.log1p(sd["koi_period"].clip(lower=0))
        sd["log1p(koi_prad)"] = np.log1p(sd["koi_prad"].clip(lower=0))
        fig_sc = px.scatter(
            sd,
            x="log1p(koi_period)",
            y="log1p(koi_prad)",
            color="koi_disposition",
            color_discrete_map=GALAXY_CLASS_PALETTE,
            opacity=0.72,
            title="Transit Period vs Planet Radius (log1p)",
        )
        st.plotly_chart(gfig(fig_sc, 360), use_container_width=True, theme=None)

    corr_feats = ["koi_period", "koi_prad", "koi_depth", "koi_duration", "koi_impact", "koi_model_snr"]
    corr = fdf[corr_feats].corr().round(2)
    fig_corr = px.imshow(
        corr,
        color_continuous_scale=[GALAXY_ACCENT1, GALAXY_BG, GALAXY_ACCENT2],
        zmin=-1,
        zmax=1,
        title="Quick Correlation Radar",
        text_auto=True,
    )
    st.plotly_chart(gfig(fig_corr, 390), use_container_width=True, theme=None)

with tab_eda:
    st.markdown("<div class='section-header'>EDA - Feature Distributions (Histograms)</div>", unsafe_allow_html=True)
    st.plotly_chart(eda_hist_grid(fdf), use_container_width=True, theme=None)

    st.markdown("<div class='section-header'>Boxplots per Class</div>", unsafe_allow_html=True)
    st.plotly_chart(eda_boxplot_grid(fdf), use_container_width=True, theme=None)

    st.markdown("<div class='section-header'>Pairplot (Top 4 Features)</div>", unsafe_allow_html=True)
    pair_features = ["koi_prad", "koi_period", "koi_depth", "koi_impact"]
    pdf = fdf[pair_features + ["koi_disposition"]].copy()
    for c in pair_features:
        pdf[c] = np.log1p(pdf[c].clip(lower=0))
    fig_pair = px.scatter_matrix(pdf.sample(min(2000, len(pdf)), random_state=7), dimensions=pair_features, color="koi_disposition", color_discrete_map=GALAXY_CLASS_PALETTE, opacity=0.75)
    fig_pair.update_traces(diagonal_visible=False, marker=dict(size=4))
    st.plotly_chart(gfig(fig_pair, 760), use_container_width=True, theme=None)

with tab_models:
    st.markdown("<div class='section-header'>Model Leaderboard</div>", unsafe_allow_html=True)
    st.dataframe(metrics_df, use_container_width=True, hide_index=True)

    st.markdown("<div class='section-header'>ROC Curves</div>", unsafe_allow_html=True)
    st.plotly_chart(build_roc_figure(analysis, models), use_container_width=True, theme=None)

with tab_infer:
    st.markdown("<div class='section-header'>Real-Time Exoplanet Classification</div>", unsafe_allow_html=True)
    choice = st.selectbox("Select Model", list(MODEL_PATHS.keys()), index=1)
    model = models[choice]
    med = analysis[FEATURE_COLS].median()
    vals = {}
    cols = st.columns(3)
    for i, ft in enumerate(FEATURE_COLS):
        with cols[i % 3]:
            vals[ft] = st.number_input(ft, value=float(med[ft]), step=0.01, format="%.5f")
    if st.button("Run Inference", use_container_width=True):
        row = pd.DataFrame([vals], columns=FEATURE_COLS)
        pred = int(model.predict(row)[0])
        proba = model.predict_proba(row)[0]
        label = {0: "FALSE POSITIVE", 1: "CONFIRMED"}[pred]
        st.success(f"Prediction: {label} | Confidence: {proba[pred]*100:.2f}%")

with tab_rules:
    st.markdown("<div class='section-header'>Association Rules</div>", unsafe_allow_html=True)
    st.info("Association rules page ready.")
